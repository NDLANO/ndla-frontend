55100bbc29e\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:3d42b7bb-6819-495a-8c1c-1e8d6b0a90ab\",\"title\":{\"title\":\"Studiespesialisering\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/studiespesialisering/7d5badf01ff2\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:e27b83e3-5cff-49b2-aac5-1ea2cc40dc53\",\"title\":{\"title\":\"Teknologi- og industrifag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/teknologi--og-industrifag/a920d0b5cbbb\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:1635f9cb-164b-431f-8e4a-fb492d56ad86\",\"title\":{\"title\":\"Ungdomsskole\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/ungdomsskole/c10e0502fe12\",\"__typename\":\"ProgrammePage\"}],\"frontpage\":{\"articleId\":38140,\"article\":{\"id\":38140,\"introduction\":\"Ingress\",\"created\":\"2023-06-02T11:53:18.000Z\",\"updated\":\"2026-03-20T12:54:02.355Z\",\"revised\":\"2026-03-19T23:00:00.000Z\",\"published\":\"2026-03-19T23:00:00.000Z\",\"language\":\"nb\",\"htmlTitle\":\"Forside!\",\"transformedContent\":{\"content\":\"<section><h2 data-text=\\\"Hva gjør vi?\\\">Hva gjør vi?</h2><p>NDLA produserer digitale læringsressurser for videregående opplæring. Ressursene våre er åpne og fritt tilgjengelige, og de fins på både bokmål og nynorsk.</p><ndlaembed data-resource=\\\"campaign-block\\\" data-heading-level=\\\"h2\\\" data-title=\\\"test\\\" data-description=\\\"tester\\\" data-image-side=\\\"left\\\" data-url=\\\"https://nrk.no\\\" data-url-text=\\\"test\\\" data-image-id=\\\"21879\\\" data-alt=\\\"asd\\\" data-json=\\\"{&quot;resource&quot;:&quot;campaign-block&quot;,&quot;embedData&quot;:{&quot;resource&quot;:&quot;campaign-block&quot;,&quot;headingLevel&quot;:&quot;h2&quot;,&quot;title&quot;:&quot;test&quot;,&quot;description&quot;:&quot;tester&quot;,&quot;imageSide&quot;:&quot;left&quot;,&quot;url&quot;:&quot;https://nrk.no&quot;,&quot;urlText&quot;:&quot;test&quot;,&quot;imageId&quot;:&quot;21879&quot;,&quot;alt&quot;:&quot;asd&quot;},&quot;status&quot;:&quot;success&quot;,&quot;data&quot;:{&quot;image&quot;:{&quot;id&quot;:&quot;21879&quot;,&quot;metaUrl&quot;:&quot;https://api.test.ndla.no/image-api/v3/images/21879&quot;,&quot;title&quot;:{&quot;title&quot;:&quot;Prøvebilde fjernsyn&quot;,&quot;language&quot;:&quot;und&quot;},&quot;alttext&quot;:{&quot;alttext&quot;:&quot;&quot;,&quot;language&quot;:&quot;nb&quot;},&quot;copyright&quot;:{&quot;license&quot;:{&quot;license&quot;:&quot;CC-BY-NC-SA-4.0&quot;,&quot;description&quot;:&quot;Creative Commons Attribution-NonCommercial-ShareAlike 4.0 International&quot;,&quot;url&quot;:&quot;https://creativecommons.org/licenses/by-nc-sa/4.0/&quot;},&quot;origin&quot;:&quot;http://www.scanpix.no&quot;,&quot;creators&quot;:[{&quot;type&quot;:&quot;photographer&quot;,&quot;name&quot;:&quot;Tom A. Kolstad&quot;}],&quot;processors&quot;:[],&quot;rightsholders&quot;:[{&quot;type&quot;:&quot;supplier&quot;,&quot;name&quot;:&quot;Aftenposten&quot;},{&quot;type&quot;:&quot;supplier&quot;,&quot;name&quot;:&quot;NTB scanpix&quot;}],&quot;processed&quot;:false},&quot;tags&quot;:{&quot;tags&quot;:[&quot;television&quot;,&quot;preview&quot;,&quot;tv screen&quot;],&quot;language&quot;:&quot;und&quot;},&quot;caption&quot;:{&quot;caption&quot;:&quot;&quot;,&quot;language&quot;:&quot;nb&quot;},&quot;supportedLanguages&quot;:[&quot;und&quot;],&quot;created&quot;:&quot;2018-12-07T18:08:29.000Z&quot;,&quot;createdBy&quot;:&quot;r0gHb9Xg3li4yyXv0QSGQczV3bviakrT&quot;,&quot;modelRelease&quot;:&quot;not-set&quot;,&quot;image&quot;:{&quot;fileName&quot;:&quot;sy753679.jpg&quot;,&quot;size&quot;:163552,&quot;contentType&quot;:&quot;image/jpeg&quot;,&quot;imageUrl&quot;:&quot;https://images.test.ndla.no/sy753679.jpg&quot;,&quot;dimensions&quot;:{&quot;width&quot;:1000,&quot;height&quot;:715},&quot;variants&quot;:[{&quot;size&quot;:&quot;icon&quot;,&quot;variantUrl&quot;:&quot;https://images.test.ndla.no/sy753679/icon.webp&quot;},{&quot;size&quot;:&quot