alt\":\"En collage av ulike bilder. Vi ser deler av et malt ansikt, en høyttaler og logoen til blant annet Youtube, Instagram  og Facebook. \",\"__typename\":\"MetaImage\"},\"traits\":[\"INTERACTIVE\",\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"25386\",\"title\":\"Hvordan kan du få inntekter og jobb?\",\"url\":\"/r/tverrfaglige-temaer/hvordan-kan-du-fa-inntekter-og-jobb/3f6510dda6\",\"metaDescription\":\"Hvordan kan du få økte inntekter? Det finnes flere måter å tjene penger, men den viktigste for de aller fleste er å skaffe seg en egen jobb.\",\"context\":{\"contextId\":\"3f6510dda6\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/41276\",\"alt\":\"Kvinne kaster mange pengesedler opp i lufta. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20977\",\"title\":\"Deutsch unplugged 1\",\"url\":\"/r/tverrfaglige-temaer/deutsch-unplugged-1/42fecd2809\",\"metaDescription\":\"\\\"Unplugged\\\"-aktivitet i skolebygget eller utendørs. Uhøytidelig rebusløp.\",\"context\":{\"contextId\":\"42fecd2809\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:tasksAndActivities\",\"name\":\"Oppgave\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/3334\",\"alt\":\"Person som holder ei skjøteledning. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20305\",\"title\":\"Når plasten ikke er fantastisk\",\"url\":\"/r/tverrfaglige-temaer/nar-plasten-ikke-er-fantastisk/4ee0164cf1\",\"metaDescription\":\"Plast kan være nyttig når den er i bruk, men hvis den kommer på avveier, kan det bli et problem for både dyr og mennesker.\",\"context\":{\"contextId\":\"4ee0164cf1\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/46803\",\"alt\":\"Fisk satt sammen av plastavfall gaper over skilpadde. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\",\"INTERACTIVE\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"27911\",\"title\":\"Dokumentaren «Influenser»\",\"url\":\"/r/tverrfaglige-temaer/dokumentaren-influenser/40b07770b5\",\"metaDescription\":\"I dokumentaren «Influenser» undersøker NRK-programleder Vilde Bratland Erikstad hvordan influenserbransjen jobber for å påvirke deg.\",\"context\":{\"contextId\":\"40b07770b5\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:SourceMaterial\",\"name\":\"Kildemateriell\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/52938\",\"alt\":\"Influenseren Sophie Elise Isachsen holder en blomsterbukett og et diplom og snakker i mikrofon på prisutdeling. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20718\",\"title\":\"Tre tips til pitch\",\"url\":\"/r/tverrfaglige-temaer/tre-tips-til-pitch/9c8737f172\",\"metaDescription\":\"Få fram poenget, øv og vær alltid klar for en framføring. Her har du tre tips til arbeid med pitch.\",\"context\":{\"contextId\":\"9c8737f172\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/47351\",\"alt\":\"Ingeborg Vollan. Skjermdump.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"16343\",\"title\":\"Hva er drivhuseffekt?\",\"url\":\"/r/tverrfaglige-temaer/hva-er-drivhuseffekt/23458701f1\",\"metaDescription\":\"Drivhuseffekt er når gasser i atmosfæren fanger opp en del av varmeenergien som jorda sender ut etter å ha blitt varmet opp av sola.\",\"context\":{\"contextId\":\"23458701f1\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/44513\",\"alt\":\"Stråling fra sola symbolisert som piler. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\",\"INTERACTIVE\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20706\",\"title\":\"Forbered intervjuet\",\"url\":\"/r/tverrfaglige-temaer/forbered-intervjuet/0343e53bc0\",\"metaDescription\":\"Planlegg gode spørsmål og gjør klar utstyr før intervjusituasjonen.\",\"context\":{\"contextId\":\"0343e53bc0\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/40523\",\"alt\":\"Ung jente rekker fram mikrofon. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"}],\"__typename\":\"Search\"}}}\n"},"headersSize":-1,"bodySize":-1,"redirectURL":""},"cache":{},"timings":{"send":-1,"wait":-1,"receive":3.828}}]}}
