eLicense\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment StructuredArticleData_Copyright on Copyright {\\n  license {\\n    url\\n    license\\n    __typename\\n  }\\n  creators {\\n    name\\n    type\\n    __typename\\n  }\\n  processors {\\n    name\\n    type\\n    __typename\\n  }\\n  rightsholders {\\n    name\\n    type\\n    __typename\\n  }\\n  processed\\n  __typename\\n}\\n\\nfragment StructuredArticleData_BrightcoveLicense on BrightcoveLicense {\\n  src\\n  title\\n  cover\\n  description\\n  download\\n  uploadDate\\n  copyright {\\n    ...StructuredArticleData_Copyright\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment StructuredArticleData_AudioLicense on AudioLicense {\\n  src\\n  title\\n  copyright {\\n    ...StructuredArticleData_Copyright\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment StructuredArticleData_PodcastLicense on PodcastLicense {\\n  src\\n  title\\n  description\\n  copyright {\\n    ...StructuredArticleData_Copyright\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment StructuredArticleData_ImageLicense on ImageLicense {\\n  src\\n  title\\n  copyright {\\n    ...StructuredArticleData_Copyright\\n    __typename\\n  }\\n  __typename\\n}\"}","params":[]}},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"br"},{"name":"Content-Type","value":"application/graphql-response+json; charset=utf-8"},{"name":"Date","value":"Fri, 12 Jun 2026 12:16:50 GMT"},{"name":"ETag","value":"W/\"9b4a-pqQo8Pn3aInKh45SzZaOGUG68Pc\""},{"name":"Keep-Alive","value":"timeout=5"},{"name":"Transfer-Encoding","value":"chunked"},{"name":"Vary","value":"Accept-Encoding"},{"name":"X-Powered-By","value":"Express"},{"name":"cache-control","value":"no-store"}],"content":{"size":-1,"mimeType":"application/graphql-response+json; charset=utf-8","text":"{\"data\":{\"programmes\":[{\"id\":\"urn:programme:2db54146-54af-4949-966a-002acf307886\",\"title\":{\"title\":\"Bygg- og anleggsteknikk\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/bygg--og-anleggsteknikk/847f59182173\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:e1a0127c-b9b2-47a5-855b-934640abdb30\",\"title\":{\"title\":\"Elektro og datateknologi\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/elektro-og-datateknologi/55ad4a85ba78\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:c4316fb8-f97b-44d3-8a7f-b65c3da71d93\",\"title\":{\"title\":\"Frisør, blomster, interiør og eksponeringsdesign\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/frisor-blomster-interior-og-eksponeringsdesign/235c13273508\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:e05b6a37-b9b2-4685-958f-ea2f999a58ac\",\"title\":{\"title\":\"Generell studiekompetanse\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/generell-studiekompetanse/fbeaae1282b9\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:22017624-90c0-4b05-bfb9-e152144445f9\",\"title\":{\"title\":\"Håndverk, design og produktutvikling\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/handverk-design-og-produktutvikling/28899b73c188\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:6c6abdff-086b-4e5d-a8db-f23d5b677ef2\",\"title\":{\"title\":\"Helse- og oppvekstfag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/helse--og-oppvekstfag/5ad439a5dacb\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:01323a26-1fa8-4e5e-bcde-7719758ccfbb\",\"title\":{\"title\":\"Idrettsfag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/idrettsfag/dd37b407714d\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:4986522e-e76c-4d9b-bd20-c4b014b5e3c1\",\"title\":{\"title\":\"Informasjonsteknologi og medieproduksjon\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/informasjonsteknologi-og-medieproduksjon/23f18a24131e\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:838201bc-dd81-4fe3-890d-96621c81562c\",\"title\":{\"title\":\"Kunst, design og arkitektur\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/kunst-design-og-arkitektur/72376dcfd25a\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:147f3fdd-2c3d-4f85-b4b3-daeae7a9aa5a\",\"title\":{\"title\":\"Medier og kommunikasjon\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/medier-og-kommunikasjon/57b0e8cd7270\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:c15de191-0a59-4aa8-91e6-4520085d3f99\",\"title\":{\"title\":\"Musikk, dans og drama\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/musikk-dans-og-drama/338394ba465c\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:d70c4eea-aed6-4551-83a6-60a551047c0c\",\"title\":{\"title\":\"Naturbruk\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/naturbruk/d23305736cde\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:a105b3a3-7a29-49be-817b-803c06892237\",\"title\":{\"title\":\"Påbygg\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/pabygg/6ea1ed34e5e7\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:a90d8927-288f-44a9-99cd-585194669421\",\"title\":{\"title\":\"Restaurant- og matfag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/restaurant--og-matfag/0a0cd4e39743\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:088a27ed-66a0-4cd1-a425-da1e1797c957\",\"title\":{\"title\":\"Salg, service og reiseliv\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/salg-service-og-reiseliv/b55100bbc29e\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:3d42b7bb-6819-495a-8c1c-1e8d6b0a90ab\",\"title\":{\"title\":\"Studiespesialisering\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/studiespesialisering/7d5badf01ff2\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:e27b83e3-5cff-49b2-aac5-1ea2cc40dc53\",\"title\":{\"title\":\"Teknologi- og industrifag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/teknologi--og-industrifag/a920d0b5cbbb\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:1635f9cb-164b-431f-8e4a-fb492d56ad86\",\"title\":{\"title\":\"Ungdomsskole\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/ungdomsskole/c10e0502fe12\",\"__typename\":\"ProgrammePage\"}],\"frontpage\":{\"articleId\":38140,\"article\":{\"id\":38140,\"introduction\":\"Ingress\",\"created\":\"2023-06-02T11:53:18.000Z\",\"updated\":\"2026-06-10T13:07:35.164Z\",\"revised\":\"2026-03-19T23:00:00.000Z\",\"published\":\"2026-06-10T13:07:35.175Z\",\"language\":\"nb\",\"htmlTitle\":\"Forside!\",\"transformedContent\":{\"content\":\"<section><h2 data-text=\\\"Bruk Min NDLA før og under eksamen!\\\">Bruk Min NDLA før og under eksamen!</h2><p>Visste du at NDLA er på lokale lister til eksamen? Du kan altså bruke lærestoffet og også lagre det på Min NDLA. Se en kort video om hvordan du lagrer dine favoritter.</p><ndlaembed data-resource=\\\"brightcove\\\" data-videoid=\\\"6395307797112\\\" data-caption=\\\"<p>I Min NDLA kan lærere og elever lagre sine favorittressurser for å ha lettere tilgang når dere trenger dem. I denne videoen lærer du hvordan man lager, sorterer og deler innhold. </p><p>Merk: Elever kan kun motta mapper, ikke dele.</p>\\\" data-account=\\\"4806596774001\\\" data-player=\\\"BkLm8fT\\\" data-title=\\\"Slik lager og deler du mapper i Min NDLA [t40RqyZXg-0]\\\" data-alt=\\\"\\\" data-json=\\\"{&quot;resource&quot;:&quot;brightcove&quot;,&quot;embedData&quot;:{&quot;resource&quot;:&quot;brightcove&quot;,&quot;videoid&quot;:&quot;6395307797112&quot;,&quot;caption&quot;:&quot;<p>I Min NDLA kan lærere og elever lagre sine favorittressurser for å ha lettere tilgang når dere trenger dem. I denne videoen lærer du hvordan man lager, sorterer og deler innhold. </p><p>Merk: Elever kan kun motta mapper, ikke dele.</p>&quot;,&quot;account&quot;:&quot;4806596774001&quot;,&quot;player&quot;:&quot;BkLm8fT&quot;,&quot;title&quot;:&quot;Slik lager og deler du mapper i Min NDLA [t40RqyZXg-0]&quot;,&quot;alt&quot;:&quot;&quot;},&quot;status&quot;:&quot;error&quot;,&quot;message&quot;:&quot;Failed to fetch data for embed of type brightcove with index 0&quot;}\\\"></ndlaembed><details><summary>Ekspanderande boks - Hvordan bruke NDLA?</summary><ul><li><p>Søk oppe til høgre.</p></li><li><p>Deretter kan du velge ulike filter for å se innhold som inneholder video, eller bare i Spansk 2 osv. </p></li><li><p>Kompetansemål er ofte lagt til på sidene. Klikk på de for å søke etter innhold merket med kompetansemålet (Kompetansemålene har en kode som starter på KM)</p></li><li><p>Over tittelen på siden kan du se hvor i strukturen du er, dette kalles brødsmulestien. Klikk for å hoppe raskt oppover i strukturen.</p></li><li><p>Under artikkelen kan du se forfatter, lisens og publiseringsdato. Klikk Sitere eller gjenbruke? for å få informasjon til referanser, finne lisenser og laste ned bilder, eller finne embedkode for video. </p></li><li><p>Logg inn på Min NDLA for å lagre, organisere og dele innhold i mapper, eller bruke prateroboter med kunstig intelligens. </p></li><li><p>Ja, og du må ha feide-konto fra fylkeskommunene i NDLA-samarbeidet for å få logge på. Private skoler, eller lærere og elever fra grunnskole, universitet eller  kan dessverre ikke logge inn, siden de ikke er med i samarbeidet. Men alle kan se delte mapper og alt innhold. </p></li><li><p>Vi publiserer på nynorsk og bokmål samtidig. Velg språk oppe på sidene for å bytte.</p></li><li><p>Vi har flere prateroboter/chatbot på NDLA, logg inn og test gjerne. Det er ikke kunstig intelligens som svarer deg på support. </p></li><li><p>Gamle og utdaterte adresser skal stort sett sende deg videre, men noen ganger må du velge på \\\"Siden har flyttet\\\". Noe innhold var for gammelt til å bli flyttet på. Dette er fjernet og vil gi feilmelding 410. </p></li><li><p>Trenger du hjelp? (Vi kan dessverre ikke hjelpe med lekser og oppgaver), bruk Spør NDLA nede til høyre)</p></li><li><p>Fasit? Klart vi har! Det koster 1000,- per svar. (Neida, hos oss er absolutt alt åpent for alle. Vi har ikke gjemt <a href=\\\"https://www.youtube.com/watch?v=dQw4w9WgXcQ\\\">fasiten</a>.)</p></li><li><p>Svaret er forresten <a href=\\\"https://www.google.com/search?client=safari&amp;rls=en&amp;q=Hva+er+meningen+med+livet+universet+og+allting\\\">42</a>. </p></li></ul></details><div data-type=\\\"framed-content\\\"><h2 data-text=\\\"Liker du å språkvaske engelsk?\\\">Liker du å språkvaske engelsk?</h2><p>Vil du være med på å fornye engelskfaget på ndla.no? Vi har en ledig læreravtale som kan gi deg denne muligheten. I tillegg får du nyttig erfaring med læremiddelutvikling, og du vil jobbe sammen med kompetente og hyggelige kollegaer. </p></div><aside data-type=\\\"factAside\\\"><h2 data-text=\\\"Slik søker du jobb hos oss\\\">Slik søker du jobb hos oss</h2><p>Her er noen viktige punkter du bør lese gjennom før du søker jobb hos oss:</p><p>Hvem kan søke? Du må være ansatt i en av landets fylkeskommuner. Relevant utdanning og kompetanse innen fagområdet er nødvendig. Erfaring fra undervisning i videregående skole og produksjon av digitale læremidler er en fordel.</p><p>Praktiske opplysninger: Medarbeidere i NDLA blir frikjøpt fra de fylkeskommunale stillingene sine og jobber vanligvis fra hjemmekontor eller på skolen de tilhører.</p><p>Søknadsprosess: Send en skriftlig søknad og cv til stilling@ndla.no, med kopi til teamlederen nevnt i utlysningsteksten. Sjekk om det er krav til innsending av arbeidsprøve før du søker.</p></aside><h2 data-text=\\\"Hva gjør vi?\\\">Hva gjør vi?</h2><p>NDLA produserer digitale læringsressurser for videregående opplæring. Ressursene våre er åpne og fritt tilgjengelige, og de fins på både bokmål og nynorsk.</p><h2 data-text=\\\"Hvem er vi?\\\">Hvem er vi?</h2><p>NDLA er et fylkeskommunalt samarbeid som tilbyr 143 eksamensfag for videregående. Vi jobber kontinuerlig med utvikling av fag.</p><ndlaembed data-resource=\\\"image\\\" data-resource_id=\\\"65086\\\" data-size=\\\"full\\\" data-align=\\\"\\\" data-alt=\\\" To ungdommer sitter og snakker. Foto. \\\" data-caption=\\\"Dette bildet skal bare brukes i casen &quot;Livet på sosiale medier&quot;. \\\" data-hide-byline=\\\"false\\\" data-url=\\\"https://api.test.ndla.no/image-api/v2/images/65086\\\" data-json=\\\"{&quot;resource&quot;:&quot;image&quot;,&quot;embedData&quot;:{&quot;resource&quot;:&quot;image&quot;,&quot;resourceId&quot;:&quot;65086&quot;,&quot;size&quot;:&quot;full&quot;,&quot;align&quot;:&quot;&quot;,&quot;alt&quot;:&quot; To ungdommer sitter og snakker. Foto. &quot;,&quot;caption&quot;:&quot;Dette bildet skal bare brukes i casen \\\\&quot;Livet på sosiale medier\\\\&quot;.&quot;,&quot;hideByline&quot;:&quot;false&quot;,&quot;url&quot;:&quot;https://api.test.ndla.no/image-api/v2/images/65086&quot;,&quot;pageUrl&quot;:&quot;/image/65086&quot;},&quot;status&quot;:&quot;success&quot;,&quot;data&quot;:{&quot;id&quot;:&quot;65086&quot;,&quot;metaUrl&quot;:&quot;https://api.test.ndla.no/image-api/v3/images/65086&quot;,&quot;title&quot;:{&quot;title&quot;:&quot;\\\\nSamtale &quot;,&quot;language&quot;:&quot;nb&quot;},&quot;alttext&quot;:{&quot;alttext&quot;:&quot; To ungdommer sitter og snakker. Foto. &quot;,&quot;language&quot;:&quot;nb&quot;},&quot;copyright&quot;:{&quot;license&quot;:{&quot;license&quot;:&quot;COPYRIGHTED&quot;,&quot;description&quot;:&quot;Copyrighted&quot;},&quot;origin&quot;:&quot;&quot;,&quot;creators&quot;:[],&quot;processors&quot;:[],&quot;rightsholders&quot;:[{&quot;type&quot;:&quot;rightsholder&quot;,&quot;name&quot;:&quot;Folkehelseprosjektet Helsefremmende miljø på sosial medier, Bergen kommune 2019-2022&quot;}],&quot;processed&quot;:fa