ainer_SearchResult\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\\nfragment SubjectContainer_SearchResult on SearchResult {\\n  ...TransportationSearchResult_SearchResult\\n  __typename\\n}\\n\\nfragment TransportationSearchResult_SearchResult on SearchResult {\\n  id\\n  title\\n  url\\n  metaDescription\\n  context {\\n    contextId\\n    relevanceId\\n    resourceTypes {\\n      id\\n      name\\n      __typename\\n    }\\n    __typename\\n  }\\n  ... on ArticleSearchResult {\\n    metaImage {\\n      url\\n      alt\\n      __typename\\n    }\\n    traits\\n    __typename\\n  }\\n  ... on LearningpathSearchResult {\\n    metaImage {\\n      url\\n      alt\\n      __typename\\n    }\\n    traits\\n    __typename\\n  }\\n  __typename\\n}\"}","params":[]}},"response":{"status":200,"statusText":"","httpVersion":"HTTP/2.0","cookies":[],"headers":[{"name":"access-control-allow-credentials","value":"true"},{"name":"access-control-allow-origin","value":"http://localhost:3000"},{"name":"access-control-expose-headers","value":"*"},{"name":"cache-control","value":"no-store"},{"name":"content-encoding","value":"br"},{"name":"content-type","value":"application/graphql-response+json; charset=utf-8"},{"name":"date","value":"Wed, 17 Jun 2026 10:06:51 GMT"},{"name":"etag","value":"W/\"1690-0Ihg7XpC5D70kXG2VdwXpErJ/+c\""},{"name":"server","value":"envoy"},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"vary","value":"Accept-Encoding"},{"name":"via","value":"1.1 d27d3f4230954794eccdc551e04ec846.cloudfront.net (CloudFront)"},{"name":"x-amz-cf-id","value":"5G_l1bv9vgyTopstnni8kLT1Oq8OPPge78PiuUhRPxoeoQgYg8w5ZQ=="},{"name":"x-amz-cf-pop","value":"ARN53-P3"},{"name":"x-cache","value":"Miss from cloudfront"},{"name":"x-envoy-upstream-service-time","value":"59"},{"name":"x-powered-by","value":"Express"}],"content":{"size":-1,"mimeType":"application/graphql-response+json; charset=utf-8","text":"{\"data\":{\"search\":{\"results\":[{\"id\":\"20955\",\"title\":\"Sosiale medier og klassemiljø\",\"url\":\"/r/verktoykassa---for-elever/sosiale-medier-og-klassemiljo/2a13ff00b8\",\"metaDescription\":\"Hva har sosiale medier å si for eget selvbilde, relasjoner til andre og klassemiljøet du tilhører? Løs oppgaver og bli bevisst ulike problemstillinger.\",\"context\":{\"contextId\":\"2a13ff00b8\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:tasksAndActivities\",\"name\":\"Oppgave\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/47583\",\"alt\":\"En collage av ulike bilder. Vi ser deler av et malt ansikt, en høyttaler og logoen til blant annet Youtube, Instagram  og Facebook. \",\"__typename\":\"MetaImage\"},\"traits\":[\"INTERACTIVE\",\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"37647\",\"title\":\"Korte filmer om psykisk helse\",\"url\":\"/r/verktoykassa---for-elever/korte-filmer-om-psykisk-helse/3b0efa87f7\",\"metaDescription\":\"Denne artikkelen inneholder korte filmer om psykisk helse laget i samarbeid med VIP Psykisk helse i skolen.\",\"context\":{\"contextId\":\"3b0efa87f7\",\"relevanceId\":\"urn:relevance:supplementary\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/13194\",\"alt\":\"Ungdommer som snakker sammen. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\",\"PODCAST\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20718\",\"title\":\"Tre tips til pitch\",\"url\":\"/r/verktoykassa---for-elever/tre-tips-til-pitch/0beb15cd87\",\"metaDescription\":\"Få fram poenget, øv og vær alltid klar for en framføring. Her har du tre tips til arbeid med pitch.\",\"context\":{\"contextId\":\"0beb15cd87\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/47351\",\"alt\":\"Ingeborg Vollan. Skjermdump.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"22694\",\"title\":\"Hvordan kan bilder skape press og stress?\",\"url\":\"/r/verktoykassa---for-elever/hvordan-kan-bilder-skape-press-og-stress/836c0b6b2f\",\"metaDescription\":\"Bildedeling på sosiale medier kan både bidra til å øke og minske press og stress blant ungdom. På hvilken måte blir du påvirket av bildene på nett? \",\"context\":{\"contextId\":\"836c0b6b2f\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:tasksAndActivities\",\"name\":\"Oppgave\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/1030\",\"alt\":\"Logoen til Twitter, Instagram, Snapchat og andre apper. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"36032\",\"title\":\"Gå på jakt etter fusk og plagiat\",\"url\":\"/r/verktoykassa---for-elever/ga-pa-jakt-etter-fusk-og-plagiat/478b45db2d\",\"metaDescription\":\"Løs en rekke caser der elever har tvilsom kildebruk. Er det juks og fanteri, tvilstilfeller eller helt greit? Målet er at du skal få kunnskap om kildebruk.\",\"context\":{\"contextId\":\"478b45db2d\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:tasksAndActivities\",\"name\":\"Oppgave\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/29772\",\"alt\":\"En gutt sitter på en bibliotekshylle og leser ei bok. Vi ser ikke hodet hans. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"31301\",\"title\":\"Møbeltapetserer\",\"url\":\"/r/verktoykassa---for-elever/mobeltapetserer/9a805baebc\",\"metaDescription\":\"Møbeltapetserere jobber med interiørsøm og stopper og trekker møbler. De kan både restaurere og produsere møbler og interiørprodukter.\",\"context\":{\"contextId\":\"9a805baebc\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/58241\",\"alt\":\"Dame setter knappenåler i stol i et møbelverksted. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"21721\",\"title\":\"Søm og tekstilhåndverk\",\"url\":\"/r/verktoykassa---for-elever/som-og-tekstilhandverk/e80ec60cab\",\"metaDescription\":\"Tekstilhåndverk er et skapende og fremtidsrettet fag. Etter søm og tekstilhåndverk i Vg2, kan du velge mellom elleve forskjellige lærefag.\",\"context\":{\"contextId\":\"e80ec60cab\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/61757\",\"alt\":\"Foto av to kjole- og draktsyere som tilpasser en jakke.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"24129\",\"title\":\"11 kreative tips til framføringer\",\"url\":\"/r/verktoykassa---for-elever/11-kreative-tips-til-framforinger/44a645250a\",\"metaDescription\":\"Tips til hvordan du kan holde interessante framføringer.\",\"context\":{\"contextId\":\"44a645250a\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/49707\",\"alt\":\"Engasjert og lyttende forsamling. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\",\"INTERACTIVE\"],\"__typename\":\"ArticleSearchResult\"}],\"__typename\":\"Search\"}}}\n"},"headersSize":-1,"bodySize":-1,"redirectURL":""},"cache":{},"timings":{"send":-1,"wait":-1,"receive":2.26}}]}}
