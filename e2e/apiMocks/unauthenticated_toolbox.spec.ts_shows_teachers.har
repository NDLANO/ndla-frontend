vanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til en god skolestart for elever og lærere.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/13252\",\"alt\":\"Tre elever foran tavle i klasserom med hvert sitt spørsmålstegn. Foto.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"407913b225\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:f8f9c269-9ca2-4fd8-889e-f71c845025a5\",\"nodeType\":\"TOPIC\",\"name\":\"Press og stress\",\"url\":\"/e/verktoykassa---for-larere/press-og-stress/ac73fd2cba\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til hvordan du kan mestre press og stress i hverdagen.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/41692\",\"alt\":\"Stressa jente holder seg til hodet, og er omgitt av personer som vil ha hennes oppmerksomhet. Foto.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"ac73fd2cba\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:cc71327e-7405-403d-b700-ab512c8617fb\",\"nodeType\":\"TOPIC\",\"name\":\"Psykisk helse\",\"url\":\"/e/verktoykassa---for-larere/psykisk-helse/0d7dea4029\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til hvordan lærere og elever kan ta tak i temaet psykisk helse.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/49340\",\"alt\":\"Tastatur med taster som viser smilefjes, surt fjes og nøytralt fjes. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"0d7dea4029\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:a4db6c9d-7890-4348-8d0f-cbeef354d3db\",\"nodeType\":\"TOPIC\",\"name\":\"Planlegg læring\",\"url\":\"/e/verktoykassa---for-larere/planlegg-laring/04449fa716\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til metoder og verktøy du kan bruke i arbeidet ditt som designer av gode læreprosesser for elevene dine.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/48918\",\"alt\":\"Smilende mann ved skrivebord kaster ark opp i lufta. Foto.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"04449fa716\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:33316fa7-e6fc-455f-8344-6ffe45433269\",\"nodeType\":\"TOPIC\",\"name\":\"Vurdering og eksamen\",\"url\":\"/e/verktoykassa---for-larere/vurdering-og-eksamen/c83591de72\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til gode vurderingsformer og til forberedelse og gjennomføring av eksamen i ulike fag.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/48916\",\"alt\":\"Kvinne med PC. I forgrunnen symboler med tommel opp og tommel ned. Foto.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"c83591de72\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:6dffd4d2-f450-422b-8fe4-e6d3c156613a\",\"nodeType\":\"TOPIC\",\"name\":\"Kommunikasjon, dialog og debatt\",\"url\":\"/e/verktoykassa---for-larere/kommunikasjon-dialog-og-debatt/f57486a7f5\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til hvordan du kan gjøre deg forstått, til debattteknikk og til hvordan du kan bidra til gode dialoger.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/43111\",\"alt\":\"Tegning av hva som foregår i hjernen til to personer som kommuniserer. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"f57486a7f5\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:f18fdf58-0cc0-40dc-9a12-9dc43e30c96e\",\"nodeType\":\"TOPIC\",\"name\":\"Entreprenørskap\",\"url\":\"/e/verktoykassa---for-larere/entreprenorskap/05f420c450\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til prosjektstyring, etablering av bedrifter og til pedagogisk entreprenørskap.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/43961\",\"alt\":\"Tre ungdommer foran en glassvegg. Foto.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"05f420c450\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:432baee9-5671-47ce-870e-48b8fc3b7a42\",\"nodeType\":\"TOPIC\",\"name\":\"Metoder i utforskning\",\"url\":\"/e/verktoykassa---for-larere/metoder-i-utforskning/ad0baf98f5\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"En innføring i ulike metoder du kan bruke for å utforske et fenomen: observasjon, spørreundersøkelse, kildestudier, feltarbeid og statistisk analyse.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/43962\",\"alt\":\"Stor hånd med forstørrelsesglass over en lang rekke mennesker i silhuett. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"ad0baf98f5\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:20f8b41f-dbcb-4f41-9c53-193ef58db220\",\"nodeType\":\"TOPIC\",\"name\":\"Digitale verktøy\",\"url\":\"/e/verktoykassa---for-larere/digitale-verktoy/66a36e949a\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Tips til noen digitale verktøy som du kan bruke i undervisning, i eget læringsarbeid og i samhandling med andre.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/42674\",\"alt\":\"Skjerm og bøker. Illustrasjon.\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"66a36e949a\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1aeea247-971c-4a9d-b438-f2f8538a53eb\",\"nodeType\":\"TOPIC\",\"name\":\"Algoritmer og programmering (Python)\",\"url\":\"/e/verktoykassa---for-larere/algoritmer-og-programmering-python/e332f6d801\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Her kan du øve på å tenke algoritmisk og å programmere i programmeringsspråket Python.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/27334\",\"alt\":\" \",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"e332f6d801\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"},{\"id\":\"urn:topic:1:de369d43-7380-460d-b80e-93f7f5631e36\",\"nodeType\":\"TOPIC\",\"name\":\"Datasikkerhet\",\"url\":\"/e/verktoykassa---for-larere/datasikkerhet/953a1a60ac\",\"relevanceId\":\"urn:relevance:core\",\"meta\":{\"metaDescription\":\"Din datasikkerhet er alltid under press. Det er mange farer og umulig å sikre seg helt, men det finnes kunnskap og tiltak som kan redusere risikoen.\",\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/48139\",\"alt\":\"Mennesker står i grupper som ser ut som jordas kontinenter. Illustrasjon\",\"__typename\":\"MetaImage\"},\"__typename\":\"Meta\"},\"context\":{\"contextId\":\"953a1a60ac\",\"breadcrumbs\":[\"Verktøykassa – for lærere\"],\"__typename\":\"TaxonomyContext\"},\"__typename\":\"Node\"}],\"subjectpage\":{\"id\":199,\"metaDescription\":\"Praktiske verktøy og råd for undervisninga.\",\"about\":{\"title\":\"Verktøykassa – for lærere\",\"visualElement\":{\"type\":\"image\",\"alt\":\"Gruppe mennesker som holder ark med spørsmålstegn foran ansikt. Foto.\",\"url\":\"https://images.test.ndla.no/id/45385\",\"imageUrl\":\"https://images.test.ndla.no/12552734.jpg\",\"imageLicense\":{\"id\":\"45385\",\"title\":\"En gru