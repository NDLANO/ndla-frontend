; includeSubDomains"},{"name":"vary","value":"Accept-Encoding"},{"name":"via","value":"1.1 4cb92bb7ec58a91bffe664e66862dd94.cloudfront.net (CloudFront)"},{"name":"x-amz-cf-id","value":"d5MRPT--ZbPasVEU754Jg5SmkQMCqtoAvHdhhnl1Hz4uxsnQ9AQpww=="},{"name":"x-amz-cf-pop","value":"ARN53-P3"},{"name":"x-cache","value":"Miss from cloudfront"},{"name":"x-envoy-upstream-service-time","value":"61"},{"name":"x-powered-by","value":"Express"}],"content":{"size":-1,"mimeType":"application/graphql-response+json; charset=utf-8","text":"{\"data\":{\"search\":{\"results\":[{\"id\":\"22427\",\"title\":\"Brainstorming\",\"url\":\"/r/verktoykassa---for-larere/brainstorming/b5e30e055c\",\"metaDescription\":\"Brainstorming er en enkel øvelse for å komme på flest mulig ideer, bli trygge på hverandre og få i gang\\r prosesser for idéutvikling. \",\"context\":{\"contextId\":\"b5e30e055c\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/50055\",\"alt\":\"Elever som gjør kreativitetsøvelsen brainstorming. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"22694\",\"title\":\"Hvordan kan bilder skape press og stress?\",\"url\":\"/r/verktoykassa---for-larere/hvordan-kan-bilder-skape-press-og-stress/8e3d1c60f5\",\"metaDescription\":\"Bildedeling på sosiale medier kan både bidra til å øke og minske press og stress blant ungdom. På hvilken måte blir du påvirket av bildene på nett? \",\"context\":{\"contextId\":\"8e3d1c60f5\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:tasksAndActivities\",\"name\":\"Oppgave\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/1030\",\"alt\":\"Logoen til Twitter, Instagram, Snapchat og andre apper. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"20985\",\"title\":\"Observasjon i markedsføring\",\"url\":\"/r/verktoykassa---for-larere/observasjon-i-markedsforing/99082fa9c7\",\"metaDescription\":\"Observasjon som metode i markedsundersøkelser kan være nyttig for en markedsfører. Med denne metoden ser du hvordan forbrukere handler og samhandler.\",\"context\":{\"contextId\":\"99082fa9c7\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/37531\",\"alt\":\"Kvinne med notatblokk. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"27317\",\"title\":\"Kunstig intelligens og påvirkning\",\"url\":\"/r/verktoykassa---for-larere/kunstig-intelligens-og-pavirkning/c10e168b55\",\"metaDescription\":\"Les om positive og negative sider ved kunstig intelligens og om hvordan maskinlæring kan påvirke individer og samfunn.\",\"context\":{\"contextId\":\"c10e168b55\",\"relevanceId\":\"urn:relevance:core\",\"resourceTypes\":[{\"id\":\"urn:resourcetype:subjectMaterial\",\"name\":\"Fagstoff\",\"__typename\":\"SearchContextResourceTypes\"}],\"__typename\":\"SearchContext\"},\"metaImage\":{\"url\":\"https://images.test.ndla.no/id/53664\",\"alt\":\"En robot sitter ved en pult og løser en regneoppgave. Foto.\",\"__typename\":\"MetaImage\"},\"traits\":[\"VIDEO\"],\"__typename\":\"ArticleSearchResult\"},{\"id\":\"27501\",\"title\":\"Konsekvenser av deepfakes\",\"url\":\"/r/verktoykassa---for-larere/konsekvenser-av-deepfakes/2a18f3dbc2\",\"metaDescription\":\"Hvordan kan deepfakes brukes til å påvirke deg og vennene dine? I denne oppgaven skal du se nærmere på \\ndeepfake-teknologien.\\n\",\"context\":{\"contextId\":\"2a18f3dbc2\",\"re