sjon/57b0e8cd7270\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:c15de191-0a59-4aa8-91e6-4520085d3f99\",\"title\":{\"title\":\"Musikk, dans og drama\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/musikk-dans-og-drama/338394ba465c\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:d70c4eea-aed6-4551-83a6-60a551047c0c\",\"title\":{\"title\":\"Naturbruk\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/naturbruk/d23305736cde\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:a105b3a3-7a29-49be-817b-803c06892237\",\"title\":{\"title\":\"Påbygg\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/pabygg/6ea1ed34e5e7\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:a90d8927-288f-44a9-99cd-585194669421\",\"title\":{\"title\":\"Restaurant- og matfag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/restaurant--og-matfag/0a0cd4e39743\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:088a27ed-66a0-4cd1-a425-da1e1797c957\",\"title\":{\"title\":\"Salg, service og reiseliv\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/salg-service-og-reiseliv/b55100bbc29e\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:3d42b7bb-6819-495a-8c1c-1e8d6b0a90ab\",\"title\":{\"title\":\"Studiespesialisering\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/studiespesialisering/7d5badf01ff2\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:e27b83e3-5cff-49b2-aac5-1ea2cc40dc53\",\"title\":{\"title\":\"Teknologi- og industrifag\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/teknologi--og-industrifag/a920d0b5cbbb\",\"__typename\":\"ProgrammePage\"},{\"id\":\"urn:programme:1635f9cb-164b-431f-8e4a-fb492d56ad86\",\"title\":{\"title\":\"Ungdomsskole\",\"language\":\"nb\",\"__typename\":\"Title\"},\"url\":\"/utdanning/ungdomsskole/c10e0502fe12\",\"__typename\":\"ProgrammePage\"}],\"frontpage\":{\"articleId\":38140,\"article\":{\"id\":38140,\"introduction\":\"Ingress\",\"created\":\"2023-06-02T11:53:18.000Z\",\"updated\":\"2026-05-12T08:07:45.502Z\",\"revised\":\"2026-03-19T23:00:00.000Z\",\"published\":\"2026-05-12T08:07:45.507Z\",\"language\":\"nb\",\"htmlTitle\":\"Forside!\",\"transformedContent\":{\"content\":\"<section><h2 data-text=\\\"Bruk Min NDLA før og under eksamen!\\\">Bruk Min NDLA før og under eksamen!</h2><p>Visste du at NDLA er på lokale lister til eksamen? Du kan altså bruke lærestoffet og også lagre det på Min NDLA. Se en kort video om hvordan du lagrer dine favoritter.</p><ndlaembed data-resource=\\\"brightcove\\\" data-videoid=\\\"6395307797112\\\" data-caption=\\\"<p>I Min NDLA kan lærere og elever lagre sine favorittressurser for å ha lettere tilgang når dere trenger dem. I denne videoen lærer du hvordan man lager, sorterer og deler innhold. </p><p>Merk: Elever kan kun motta mapper, ikke dele.</p>\\\" data-account=\\\"4806596774001\\\" data-player=\\\"BkLm8fT\\\" data-title=\\\"Slik lager og deler du mapper i Min NDLA [t40RqyZXg-0]\\\" data-alt=\\\"\\\" data-json=\\\"{&quot;resource&quot;:&quot;brightcove&quot;,&quot;embedData&quot;:{&quot;resource&quot;:&quot;brightcove&quot;,&quot;videoid&quot;:&quot;6395307797112&quot;,&quot;caption&quot;:&quot;<p>I Min NDLA kan lærere og elever lagre sine favorittressurser for å ha lettere tilgang når dere trenger dem. I denne videoen lærer du hvordan man lager, sorterer og deler innhold. </p><p>Merk: Elever kan kun motta mapper, ikke dele.</p>&quot;,&quot;account&quot;:&quot;4806596774001&quot;,&quot;player&quot;:&quot;BkLm8fT&quot;,&quot;title&quot;:&quot;Slik lager og deler du mapper i Min NDLA [t40RqyZXg-0]&quot;,&quot;alt&quot;:&quot;&quot;,&quot;pageUrl&quot;:&quot;/video/6395307797112&quot;},&quot;status&quot;:&quot;success&quot;,&quot;data&quot;:{&quot;id&quot;:&quot;6395307797112&quot;,&quot;account_id&quot;:&quot;4806596774001&quot;,&quot;ad_keys&quot;:null,&quot;clip_source_video_id&quot;:null